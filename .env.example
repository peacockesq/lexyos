# LexyOS Shell environment sample
# Copy to .env or export these in your deployment environment. Do not commit live IDs or tokens.

# local (default product backend): JSON store documents in LEXYOS_DATA_PATH
LEXYOS_STORAGE_PROVIDER=local
LEXYOS_DATA_PATH=./data/lexyos.json

# safe OSS/no-op mode: no external services, upload/download requests return explicit no-op results
# LEXYOS_STORAGE_PROVIDER=mock

# live Google Drive product mode through GOG/team Google Workspace
# LEXYOS_STORAGE_PROVIDER=google_drive
# LEXYOS_GOG_ACCOUNT=team
# LEXYOS_DRIVE_ROOT_FOLDER_ID=replace-with-deployment-root-folder-id

# no-code/intake sources
# LEXY_NOCODB_BASE_URL=https://nocodb.example.test
# LEXY_NOCODB_MATTERS_TABLE_ID=replace-with-table-id
# LEXY_NOCODB_TOKEN=replace-with-token
# LEXY_INTAKE_MATTERS_ENDPOINT=https://hooks.example.test/lexyos/intake

# shared LexyAlgo B2B Supabase SSO
# LEXYOS_AUTH_MODE=supabase
# LEXYOS_SITE_URL=https://os.lexyalgo.com
# LEXYOS_SUPABASE_URL=https://your-project.supabase.co
# LEXYOS_SUPABASE_ANON_KEY=replace-with-public-anon-key
# LEXYOS_AUTH_TENANTS_JSON=[{"id":"peacock","name":"Peacock Law Firm","allowedDomains":["williepeacock.com","peacockesq.com"]}]
# LEXYOS_B2B_PRODUCTS_JSON=[{"id":"lexyfile","name":"LexyFile","url":"https://file.lexyalgo.com","role":"filing and file workspace"}]
